# Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to the repository.

# MongoDB connection string (complete URI with credentials)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database?appName=appName

# Google Drive configuration
DRIVE_BASE_FOLDER_ID=your-folder-id-here
DRIVE_WEBHOOK_URL=https://your-public-domain.com/api/drive/webhook

# Ngrok authentication token (optional, for local tunneling)
NGROK_AUTH_TOKEN=your-ngrok-token-here

# Cloudflare R2 credentials
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=drive-cards
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev
